{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/SourceType",
  "title": "SourceType",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "database",
        "saas",
        "file-storage",
        "api"
      ]
    },
    "icon": {
      "type": "string",
      "format": "uri"
    }
  }
}