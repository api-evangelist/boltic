{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Workflow",
  "title": "Workflow",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "draft"
      ]
    },
    "trigger": {
      "$ref": "#/components/schemas/Trigger"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/Node"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "executionCount": {
      "type": "integer",
      "description": "Total number of times this workflow has been executed"
    },
    "lastExecutedAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}