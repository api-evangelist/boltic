{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Row",
  "title": "Row",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "fields": {
      "type": "object",
      "additionalProperties": true,
      "description": "Key-value pairs of column names to values"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}