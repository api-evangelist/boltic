{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/RouteInput",
  "title": "RouteInput",
  "type": "object",
  "required": [
    "name",
    "paths",
    "serviceId"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "methods": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "serviceId": {
      "type": "string"
    },
    "stripPath": {
      "type": "boolean"
    },
    "preserveHost": {
      "type": "boolean"
    },
    "protocols": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive"
      ]
    }
  }
}