{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/NodeInput",
  "title": "NodeInput",
  "type": "object",
  "required": [
    "type",
    "name"
  ],
  "properties": {
    "type": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "integrationId": {
      "type": "string"
    },
    "config": {
      "type": "object",
      "additionalProperties": true
    },
    "position": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      }
    },
    "connections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "targetNodeId": {
            "type": "string"
          },
          "condition": {
            "type": "string"
          }
        }
      }
    }
  }
}