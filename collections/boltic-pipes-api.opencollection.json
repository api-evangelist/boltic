{
  "opencollection": "1.0.0",
  "info": {
    "name": "Boltic Pipes API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Pipes",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Boltic List all pipes",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.boltic.io/v1/pipes",
            "params": [
              {
                "name": "page",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "status",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Retrieve a list of all data synchronization pipelines."
        },
        {
          "info": {
            "name": "Boltic Create a new pipe",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.boltic.io/v1/pipes",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create a new data synchronization pipeline between a source and destination."
        },
        {
          "info": {
            "name": "Boltic Get a pipe by ID",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.boltic.io/v1/pipes/:pipeId",
            "params": [
              {
                "name": "pipeId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Boltic Get a pipe by ID"
        },
        {
          "info": {
            "name": "Boltic Update a pipe",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.boltic.io/v1/pipes/:pipeId",
            "params": [
              {
                "name": "pipeId",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Boltic Update a pipe"
        },
        {
          "info": {
            "name": "Boltic Delete a pipe",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.boltic.io/v1/pipes/:pipeId",
            "params": [
              {
                "name": "pipeId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Boltic Delete a pipe"
        },
        {
          "info": {
            "name": "Boltic Trigger a manual sync",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.boltic.io/v1/pipes/:pipeId/trigger",
            "params": [
              {
                "name": "pipeId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Initiate an immediate data synchronization run for a pipe."
        },
        {
          "info": {
            "name": "Boltic Pause a pipe",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.boltic.io/v1/pipes/:pipeId/pause",
            "params": [
              {
                "name": "pipeId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Boltic Pause a pipe"
        },
        {
          "info": {
            "name": "Boltic Resume a paused pipe",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.boltic.io/v1/pipes/:pipeId/resume",
            "params": [
              {
                "name": "pipeId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Boltic Resume a paused pipe"
        }
      ]
    },
    {
      "info": {
        "name": "Sync Runs",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Boltic List sync runs for a pipe",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.boltic.io/v1/pipes/:pipeId/runs",
            "params": [
              {
                "name": "pipeId",
                "value": "",
                "type": "path"
              },
              {
                "name": "page",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Retrieve the sync execution history for a pipe."
        }
      ]
    },
    {
      "info": {
        "name": "Sources",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Boltic List available source types",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.boltic.io/v1/sources"
          },
          "docs": "Boltic List available source types"
        }
      ]
    },
    {
      "info": {
        "name": "Destinations",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Boltic List available destination types",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.boltic.io/v1/destinations"
          },
          "docs": "Boltic List available destination types"
        }
      ]
    }
  ],
  "bundled": true
}